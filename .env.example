# ─────────────────────────────────────────────────────────────
# Telegram Stars Bot — пример конфигурации.
# Скопируйте в .env (`cp .env.example .env`) и заполните значения.
# Файл .env НИКОГДА не коммитится (см. .gitignore).
# ─────────────────────────────────────────────────────────────

# Токен Telegram-бота от @BotFather
BOT_TOKEN=

# Токен мерчанта WATA (ЛК: https://merchant.wata.pro/ или sandbox)
WATA_TOKEN=

# Базовый URL Digital Goods API (sandbox эквайринга: https://api-sandbox.wata.pro/api/h2h/)
WATA_BASE_URL=https://dg-api.wata.pro/api

# URL публичного ключа WATA для проверки подписи вебхука (RSA SHA-512)
WATA_PUBLIC_KEY_URL=https://api.wata.pro/api/h2h/public-key

# Наценка над minPrice в процентах. Итог клампится в [minPrice*count, minPrice*count*1.5] (макс +50%)
MARKUP_PERCENT=20

# Автоматически подтверждать выдачу звёзд (Review -> Paid) после оплаты
AUTO_CONFIRM=true

# Тестовый режим: не создавать реальные ссылки WATA. Вместо оплаты появляется
# кнопка «Я оплатил (ТЕСТ)» — для проверки реферальной/партнёрской программы.
TEST_MODE=false

# @username, по которому считается отображаемый в меню курс «1 ⭐» (кэш ~1 час).
RATE_REFERENCE_USERNAME=hahahahgaha

# Telegram ID администраторов через запятую (для /stats), напр. 12345,67890
ADMIN_IDS=

# Подключение к PostgreSQL (внутри docker-compose хост = postgres)
DATABASE_URL=postgresql+asyncpg://bot:bot@postgres:5432/wata_bot

# Подключение к Redis (FSM-хранилище)
REDIS_URL=redis://redis:6379/0

# ОБЯЗАТЕЛЬНО: бот работает в режиме webhook (и Telegram, и WATA шлют сюда).
# Публичный домен, на который смотрит ваш reverse proxy (напр. bot.example.com)
WEBHOOK_HOST=

# HTTP-порт webhook-сервера ВНУТРИ контейнера (за прокси, без TLS)
WEBHOOK_PORT=8080

# Путь, на который WATA шлёт уведомления (укажите в ЛК WATA: https://<домен><WEBHOOK_PATH>)
WEBHOOK_PATH=/wata/webhook

# Необязательный доп. секрет WATA-вебхука (заголовок X-Webhook-Secret), если используете
WEBHOOK_SECRET=

# Путь Telegram-вебхука (Telegram шлёт обновления на https://<домен><TELEGRAM_WEBHOOK_PATH>)
TELEGRAM_WEBHOOK_PATH=/tg/webhook

# Секрет Telegram-вебхука (заголовок X-Telegram-Bot-Api-Secret-Token).
# Если пусто — генерируется автоматически из BOT_TOKEN. Рекомендуется задать свой.
TELEGRAM_WEBHOOK_SECRET=

# Партнёрская программа: процент вознаграждения с каждой оплаты приглашённого.
REFERRAL_PERCENT=5
# Комиссия владельца партнёрского бота с каждой продажи через его бота (% от суммы).
PARTNER_COMMISSION_PERCENT=10
# Минимальная сумма вывода (в рублях) по способам.
WITHDRAW_MIN_SBP=500
WITHDRAW_MIN_CRYPTO=1000

# Ссылка на пользовательское соглашение / публичную оферту (кнопка в разделе «Помощь»).
# Оставьте пустым, чтобы скрыть кнопку «Оферта».
TERMS_URL=https://telegra.ph/POLZOVATELSKOE-SOGLASHENIE-PUBLICHNAYA-OFERTA-06-19

# Ссылка на политику конфиденциальности (кнопка в разделе «Помощь»).
PRIVACY_URL=https://telegra.ph/POLITIKA-KONFIDENCIALNOSTI-I-OBRABOTKI-PERSONALNYH-DANNYH-06-19

# Контакт поддержки (кнопка в разделе «Помощь»). Пусто — кнопка скрыта.
SUPPORT_URL=https://t.me/nnstorecontactbot

# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
